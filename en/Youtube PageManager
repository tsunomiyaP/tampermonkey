      if ('www.youtube.com' === location.hostname) {
        YtChannel = mode.pc.userNam;
      } else if ('m.youtube.com' === location.hostname) {
        YtChannel = mode.mobile.userNam;
      }

      const strData = device;
      youtubeItem.ytTitle = strData.ytTitle;
      youtubeItem.userNam = strData.userNam;

      let user = '';
      // 閲覧チャンネルのみ表示
      if ('www.youtube.com' === location.hostname) {
        const channel = document.querySelector('div#owner ytd-video-owner-renderer ytd-channel-name#channel-name #text-container > yt-formatted-string#text[title]');
        user = channel.title;
      }
      if ('m.youtube.com' === location.hostname) {
        const channel = document.querySelector('ytm-slim-owner-renderer h3.slim-owner-channel-name span');
        user = channel.textContent;
      }

      console.log(user, YtChannel);
      if (user !== YtChannel) { item.classList.add('remove_item'); }
    } else if (new RegExp(regChannel, 'gis').test(location.pathname)) {
      // pc 動画
      mode.pc.ytTitle = isNuN(item.querySelector('div#dismissible div#details div#meta > h3')) ? '' : item.querySelector('div#dismissible div#details div#meta > h3').textContent;
      mode.pc.userNam = isNuN(item.querySelector('div#dismissible div#details div#meta > h3')) ? '' : item.querySelector('div#dismissible div#details div#meta > h3').textContent;
      // mobile
      mode.mobile.ytTitle = isNuN(item.querySelector('div.YtmCompactMediaItemMetadata h4.YtmCompactMediaItemHeadline')) ? '' : item.querySelector('div.YtmCompactMediaItemMetadata h4.YtmCompactMediaItemHeadline').textContent;
      mode.mobile.userNam = isNuN(item.querySelector('div.YtmCompactMediaItemMetadata h4.YtmCompactMediaItemHeadline')) ? '' : item.querySelector('div.YtmCompactMediaItemMetadata h4.YtmCompactMediaItemHeadline').textContent;

      const strData = device;
      youtubeItem.ytTitle = strData.ytTitle;
      youtubeItem.userNam = strData.userNam;
    } else {
      // pc 動画
      mode.pc.ytTitle = isNuN(item.querySelector('yt-lockup-view-model div.yt-lockup-metadata-view-model__text-container span')) ? '' : item.querySelector('yt-lockup-view-model div.yt-lockup-metadata-view-model__text-container span').textContent;
      mode.pc.userNam = isNuN(item.querySelector('yt-lockup-view-model div.yt-content-metadata-view-model__metadata-row span')) ? '' : item.querySelector('yt-lockup-view-model div.yt-content-metadata-view-model__metadata-row span').textContent;
      // mobile
      mode.mobile.ytTitle = isNuN(item.querySelector('div.details div.media-item-info div.media-item-metadata h3.media-item-headline')) ? '' : item.querySelector('div.details div.media-item-info div.media-item-metadata h3.media-item-headline').textContent;
      mode.mobile.userNam = isNuN(item.querySelector('div.details div.media-item-info div.media-item-metadata ytm-badge-and-byline-renderer')) ? '' : item.querySelector('div.details div.media-item-info div.media-item-metadata ytm-badge-and-byline-renderer').textContent;

      const strData = device;
      youtubeItem.ytTitle = strData.ytTitle;
      youtubeItem.userNam = strData.userNam;
    }

    const words = isNuN(abc) ? '' : abc.hideword;
    const excludes = isNuN(abc) ? '' : abc.execludeWords;

    if (isNuN(words)) { return false; }
    const txt = youtubeItem.userNam + youtubeItem.ytTitle;
    for (const word of words) {
      if (new RegExp(word, 'gis').test(txt)) {
        item.classList.add('remove_item');
        youtubeItem.word = word;
        console.log('> hide all words : ', youtubeItem);
        break;
      }
    }

    if (isNuN(excludes)) { return false; }
    for (const word of excludes) {
      if (new RegExp(word, 'gis').test(txt)) {
        item.classList.remove('remove_item');
        // console.log('> un hide words : ', youtubeItem);
        break;
      }
    }
  };
  const scaleShowMovie = async (ytArea, item) => {
    if (!item.classList.contains('target')) {
      item.classList.add('target');
      // console.log('test2 1件ずつ', item);
      await removeMovieInformation(item);

      item.classList.add('show');
      item.classList.add('minScale');

      document.addEventListener('click', async (e) => {
        if (e.target.classList.contains('target')) {

          const device = 'www.youtube.com' === location.hostname || 'm.youtube.com' === location.hostname ? true : false;
          if (device && new RegExp(regSearch, 'gis').test(location.pathname)) {
            for (const result of ytArea.querySelectorAll('ytd-item-section-renderer > div#contents, ytm-item-section-renderer > lazy-list')) {
              for (const ytItem of result.children) {
                ytItem.classList.add('minScale');
              }
            }
          }

          for (const ytItem of ytArea.children) {
            ytItem.classList.add('minScale');
          }
          e.target.classList.remove('minScale');
        }
      });
    }
  };
  const ytMovieList = async (area) => {
    if (new RegExp(regSearch, 'gis').test(location.pathname)) {
      // console.log('> ytMovie search result');
      for (const result of area.querySelectorAll('ytd-item-section-renderer > div#contents, ytm-item-section-renderer > lazy-list')) {
        for (const item of result.children) {
          scaleShowMovie(area, item);
        }
      }
    } else {
      // console.log('> ytMovie check result...');
      for (const item of area.children) {
        scaleShowMovie(area, item);
      }
