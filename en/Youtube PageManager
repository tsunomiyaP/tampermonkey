    if (!isNuN(setting)) { setting.click(); }

    const drcMenuItem = await waitQuerySelectorCount(4, drcBtn);
    if (isNuN(drcMenuItem)) {
      document.querySelector(closeArea).click();
      console.log('DRC Audio is already disabled');
    } else {
      if (drcMenuItem.getAttribute('aria-checked') === 'true') {
        drcMenuItem.click();
        console.log('Disabled DRC Audio');
      } else {
        console.log('DRC Audio is already disabled');
